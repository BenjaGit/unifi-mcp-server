# UniFi MCP minimal configuration

# Preferred connection type: cloud-v1, cloud-ea, or local
UNIFI_API_TYPE=cloud-v1

# Local key (typically read/write, no Site Manager scope)
# Create from Local Site -> Integrations -> Create API Key
# UNIFI_LOCAL_API_KEY=your-local-api-key

# Remote key (typically read-only, includes Site Manager cloud scope)
# Create from unifi.ui.com -> API (or Settings -> API Keys in EA)
# UNIFI_REMOTE_API_KEY=your-remote-api-key

# Local gateway host (required only when UNIFI_API_TYPE=local)
# UNIFI_LOCAL_HOST=192.168.2.1

# Optional: enforce local certificate validation (default is false)
# UNIFI_LOCAL_VERIFY_SSL=true
