{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.enuno/unifi-mcp-server",
  "description": "An MCP server that leverages official UniFi API",
  "repository": {
    "url": "https://github.com/enuno/unifi-mcp-server",
    "source": "github"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "unifi-mcp-server",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "UniFi Controller hostname or IP address",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "UNIFI_HOST"
        },
        {
          "description": "UniFi Controller username",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "UNIFI_USERNAME"
        },
        {
          "description": "UniFi Controller password",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "UNIFI_PASSWORD"
        },
        {
          "description": "UniFi Controller port (default: 443)",
          "isRequired": false,
          "format": "number",
          "isSecret": false,
          "name": "UNIFI_PORT"
        },
        {
          "description": "Verify SSL certificate (default: true)",
          "isRequired": false,
          "format": "boolean",
          "isSecret": false,
          "name": "UNIFI_VERIFY_SSL"
        },
        {
          "description": "UniFi site name (default: default)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "UNIFI_SITE"
        }
      ]
    }
  ]
}
