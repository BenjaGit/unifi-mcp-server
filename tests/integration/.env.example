# UniFi Integration Test Environment Configuration
# Copy this file to tests/integration/.env and fill in your values.
#
# Notes:
# - The harness can reuse your main runtime env values.
# - "Lab" and "Home" are just two named test targets in this repo.
#   They are labels, not UniFi product concepts.
# - Use only "Lab" if you test one environment; add "Home" for a second one.
# - For the "unifi-lab" environment, host falls back to UNIFI_LOCAL_HOST.
# - The "unifi-home" environment is only created when BOTH key and host are set.

# Optional explicit LAB LOCAL key override (leave blank to reuse main env)
UNIFI_LAB_API_KEY=
UNIFI_LAB_HOST=
UNIFI_LAB_PORT=443
UNIFI_LAB_VERIFY_SSL=false

# Optional explicit HOME LOCAL key override
UNIFI_HOME_API_KEY=
UNIFI_HOME_HOST=
UNIFI_HOME_PORT=443
UNIFI_HOME_VERIFY_SSL=false

# Optional explicit cloud key overrides
# Defaults prefer REMOTE key (UNIFI_REMOTE_API_KEY / UNIFI_SITE_MANAGER_API_KEY),
# then LOCAL key (UNIFI_LOCAL_API_KEY / UNIFI_NETWORK_API_KEY).
UNIFI_CLOUD_V1_API_KEY=
UNIFI_CLOUD_EA_API_KEY=

# Optional cloud site IDs (defaults are built into harness)
UNIFI_CLOUD_SITE_LAB=
UNIFI_CLOUD_SITE_HOME=

# Canonical REMOTE key aliases (use either name)
# UNIFI_REMOTE_API_KEY=
# UNIFI_LOCAL_API_KEY=

# Optional Site Manager key alias (same value as UNIFI_REMOTE_API_KEY)
UNIFI_SITE_MANAGER_API_KEY=

# Test runner settings
TEST_VERBOSE=false
TEST_EXPORT_RESULTS=true
TEST_RESULTS_DIR=./test_results
